{
  "SchemaVersion": 1,
  "Source": "installer/contracts/build.json",
  "DefaultOutputDirectory": "dist",
  "BuildEntrypoints": {
    "Windows": {
      "Script": "installer/build.ps1",
      "AllowedPlatforms": [
        "Windows"
      ],
      "Artifacts": [
        "bootstrap.ps1",
        "install.ps1",
        "manage.ps1"
      ]
    },
    "MacOS": {
      "Script": "installer/build.sh",
      "AllowedPlatforms": [
        "macos"
      ],
      "Artifacts": [
        "install.sh",
        "manage.sh"
      ]
    },
    "ReleaseArtifacts": [
      "bootstrap.ps1",
      "install.ps1",
      "manage.ps1",
      "install.sh",
      "manage.sh"
    ]
  },
  "Windows": {
    "StepContract": "contracts/steps.json",
    "CanonicalStepPrefix": "windows/",
    "CommonStepFiles": [
      "windows/steps/_NpmToolCommon.ps1"
    ],
    "Artifacts": [
      {
        "Role": "Bootstrap",
        "OutputFile": "bootstrap.ps1",
        "RequiresHeader": "#Requires -Version 5.1",
        "EntryFile": "windows/Bootstrap.ps1",
        "HoistParamFrom": "",
        "OutputEncoding": "UTF8",
        "CoreFiles": [
          "windows/core/Admin.ps1",
          "windows/core/Ui.ps1",
          "windows/core/Process.ps1"
        ],
        "IncludeSteps": false
      },
      {
        "Role": "Install",
        "OutputFile": "install.ps1",
        "RequiresHeader": "#Requires -Version 7.0",
        "EntryFile": "windows/Install.ps1",
        "HoistParamFrom": "windows/Install.ps1",
        "OutputEncoding": "UTF8",
        "CoreFiles": [
          "windows/core/Ui.ps1",
          "windows/core/Process.ps1",
          "windows/core/Profile.ps1",
          "windows/core/Admin.ps1",
          "windows/core/Net.ps1",
          "windows/core/Registry.ps1",
          "windows/core/Bootstrap.ps1",
          "windows/core/McpManager.ps1",
          "windows/core/Provider.ps1"
        ],
        "IncludeSteps": true
      },
      {
        "Role": "Manage",
        "OutputFile": "manage.ps1",
        "RequiresHeader": "#Requires -Version 7.0",
        "EntryFile": "windows/Manage.ps1",
        "HoistParamFrom": "windows/Manage.ps1",
        "OutputEncoding": "UTF8",
        "CoreFiles": [
          "windows/core/Ui.ps1",
          "windows/core/Process.ps1",
          "windows/core/Profile.ps1",
          "windows/core/Admin.ps1",
          "windows/core/Net.ps1",
          "windows/core/Registry.ps1",
          "windows/core/Bootstrap.ps1",
          "windows/core/McpManager.ps1",
          "windows/core/Provider.ps1"
        ],
        "IncludeSteps": true
      }
    ]
  },
  "MacOS": {
    "StepContract": "contracts/steps.json",
    "CommonStepFile": "macos/steps/_NpmToolCommon.zsh",
    "CoreFiles": [
      "macos/core/Ui.zsh",
      "macos/core/Process.zsh",
      "macos/core/Profile.zsh",
      "macos/core/Platform.zsh",
      "macos/core/PackageManager.zsh",
      "macos/core/Json.zsh",
      "macos/core/Registry.zsh",
      "macos/core/Bootstrap.zsh",
      "macos/core/Provider.zsh",
      "macos/core/McpManager.zsh",
      "macos/core/Update.zsh"
    ],
    "Artifacts": [
      {
        "Role": "Install",
        "OutputFile": "install.sh",
        "EntryFile": "macos/Install.zsh",
        "IncludeSteps": true,
        "Wrapper": "bash-to-zsh"
      },
      {
        "Role": "Manage",
        "OutputFile": "manage.sh",
        "EntryFile": "macos/Manage.zsh",
        "IncludeSteps": true,
        "Wrapper": "bash-to-zsh"
      }
    ]
  }
}
