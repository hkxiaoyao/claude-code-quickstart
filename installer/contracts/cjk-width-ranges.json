{
  "$schema": "https://json-schema.org/draft-07/schema",
  "title": "CJK Width Ranges Contract",
  "description": "CJK 字符宽度检测码点范围（双平台共享）",
  "version": "1.0.0",
  "contract": {
    "ranges": [
      {
        "start": "0x2E80",
        "end": "0x9FFF",
        "description": "CJK 部首 + 康熙部首 + 统一汉字",
        "width": 2
      },
      {
        "start": "0x3000",
        "end": "0x303F",
        "description": "CJK 符号和标点",
        "width": 2
      },
      {
        "start": "0x3400",
        "end": "0x4DBF",
        "description": "CJK 扩展 A",
        "width": 2
      },
      {
        "start": "0xF900",
        "end": "0xFAFF",
        "description": "CJK 兼容表意文字",
        "width": 2
      },
      {
        "start": "0xFE30",
        "end": "0xFE4F",
        "description": "CJK 兼容形式",
        "width": 2
      },
      {
        "start": "0xFF00",
        "end": "0xFF60",
        "description": "全角 ASCII / 全角标点",
        "width": 2
      },
      {
        "start": "0xFFE0",
        "end": "0xFFE6",
        "description": "全角符号",
        "width": 2
      },
      {
        "start": "0x1F300",
        "end": "0x1FAFF",
        "description": "Emoji（扩展象形文字）",
        "width": 2,
        "platforms": ["macos"],
        "note": "Windows Ui.ps1 缺失此段，需补齐对齐 macOS"
      }
    ],
    "menuKeyMapping": {
      "description": "菜单键宽度统一为 1（即使是全角数字，也占用 1 个宽度计算单位）"
    }
  }
}
