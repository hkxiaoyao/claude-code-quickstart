{
  "$schema": "https://json-schema.org/draft-07/schema",
  "title": "Profile Subsections Contract",
  "description": "PowerShell $PROFILE / zsh ~/.zprofile 子段标记格式与托管块定义",
  "version": "1.0.0",
  "contract": {
    "managedBlockMarkers": {
      "startMarker": "# >>> Claude Code Quickstart >>>",
      "endMarker": "# <<< Claude Code Quickstart <<<"
    },
    "subsectionFormat": {
      "beginMarker": "# [CCQ:{NAME}:BEGIN]",
      "endMarker": "# [CCQ:{NAME}:END]",
      "description": "子段标记格式，{NAME} 为子段名称（大写）"
    },
    "subsections": [
      {
        "name": "FNM",
        "description": "fnm (Fast Node Manager) 初始化脚本",
        "sourceStep": "NodeJS",
        "platforms": ["windows", "macos"]
      },
      {
        "name": "SHORTCUTS",
        "description": "ccq / ccp / ccupdate 等快捷函数",
        "sourceStep": "Profile",
        "platforms": ["windows", "macos"]
      }
    ],
    "targetProfiles": {
      "windows": "$PROFILE (Documents\\PowerShell\\Microsoft.PowerShell_profile.ps1)",
      "macos": "~/.zprofile and ~/.zshrc"
    }
  }
}
